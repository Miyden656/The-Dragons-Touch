# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/

# Build / packaging
build/
dist/
*.spec
# Our tracked PyInstaller spec — exception to the *.spec ignore.
!TheDragonsTouch.spec

# Local generated outputs
Outputs/
outputs/

# Per-user runtime state — these get regenerated by the app on first run
# and contain absolute paths to the user's local collection / decklist folder.
# Never commit these to a public repo.
ui/user_settings.json
settings/runtime_data_setup_status.json
output/
reports/generated/

# Large downloaded card data
data/scryfall_cards.json
data/oracle-cards*.json
data/default-cards*.json
data/all-cards*.json
data/combo.json
data/commander_spellbook/combo_index.json
data/commander_spellbook/combo_index_parity.json

# Local/private collection data — ignore .txt contents but keep the
# collection/ folder visible so users see where to put their files.
# A README.md inside the folder explains the format.
collection/*.txt

# Decklists — same pattern: ignore .txt contents, keep folder.
Decklists/*.txt

# Old internal backups
Old Do not use/
old_do_not_use/
Files outside/
ui\Retired UI

# Debug and temp
debug/
debug_output/
logs/
*.log
tmp/
temp/

# OS / editor files
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# Alpha packaging / old alpha handoff folders
ALPHA TESTING/
*.zip

# Local dev-only tools & notes
Dev tools/

